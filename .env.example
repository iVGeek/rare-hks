# Server
PORT=3000

# Admin login — set ADMIN_PASSWORD (plain text, auto-hashed at startup)
# For Render, pre-hash with: node -e "require('crypto').createHash('sha256').update('yourpass').digest('hex')" and set ADMIN_PASSWORD_HASH
ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH=

# Supabase — get from https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Paystack — sk_test_ for test mode, sk_live_ for production
PAYSTACK_SECRET_KEY=

# Gmail SMTP App Password — https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional: base URL for product images (defaults to legacy project storage)
# STORE_IMAGE_BASE_URL=
